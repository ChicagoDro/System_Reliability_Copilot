# =============================================================================
# System Reliability Copilot — Environment Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Provider — pick one block and uncomment it
# -----------------------------------------------------------------------------

# -- OpenAI --
#LLM_PROVIDER=openai
#OPENAI_API_KEY=your_openai_key_here
#OPENAI_CHAT_MODEL=gpt-4o               # or gpt-4.1, gpt-4.1-mini, etc.
#OPENAI_EMBED_MODEL=text-embedding-3-large

# -- Grok (xAI, OpenAI-compatible) --
#LLM_PROVIDER=grok
#GROK_API_KEY=your_grok_key_here
#GROK_MODEL=grok-2-latest

# -- Gemini (default) --
LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_key_here
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=gemini-embedding-001   # v1beta API model — do NOT prefix with "models/"

# -----------------------------------------------------------------------------
# LLM tuning
# -----------------------------------------------------------------------------
LLM_TEMPERATURE=0.2

# -----------------------------------------------------------------------------
# Neo4j AuraDB — graph + vector database
# Get your connection details from https://console.neo4j.io
# -----------------------------------------------------------------------------
NEO4J_URI=neo4j+s://<instance-id>.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
NEO4J_DATABASE=neo4j

# Vector index names (created automatically on first ingest — safe to leave as-is)
NEO4J_VENDOR_DOCS_INDEX=vendor_docs
NEO4J_RUNBOOKS_INDEX=runbooks

# -----------------------------------------------------------------------------
# LangSmith — observability + evaluation (optional but recommended)
# Get your key from https://smith.langchain.com
# -----------------------------------------------------------------------------
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_key_here
LANGCHAIN_PROJECT=system-reliability-copilot
